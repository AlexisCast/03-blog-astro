---
import MainLayout from "src/layouts/MainLayout.astro";
import { Image } from "astro:assets";
import "../../styles/blog.css";

import post05Img from "@images/post-05.png";
import post03Img from "@images/post-03.png";
import { Picture } from "astro:assets";
---

<MainLayout>
	<h1 class="text-5xl text-white">Images</h1>

	<img
		loading="eager"
		src="/assets/images/post-05.png"
		width="250"
		height="250"
	/>

	<Image src={post05Img} width="250" height="250" alt="Image from post" />
	<Image
		src={post05Img}
		style={{
			with: "250px",
			height: "250px",
		}}
		width="500"
		height="500"
		alt="Image from post"
	/>
	<h1>Quality Low</h1>
	<Image
		src={post05Img}
		quality="low"
		width="250"
		height="250"
		alt="Image from post"
	/>

	<h1>Quality Mid</h1>
	<Image
		src={post05Img}
		quality="mid"
		width="250"
		height="250"
		alt="Image from post"
	/>

	<h1>Quality High</h1>
	<Image
		src={post05Img}
		quality="high"
		width="250"
		height="250"
		alt="Image from post"
	/>

	<h1>Quality Max</h1>
	<Image
		src={post05Img}
		quality="max"
		width="250"
		height="250"
		alt="Image from post"
	/>

	<h1>Formats</h1>
	<h1>Format jpg</h1>
	<Image
		src={post05Img}
		format="jpg"
		width="250"
		height="250"
		alt="Image from post"
	/>

	<h1>Format avif</h1>
	<Image
		src={post05Img}
		format="avif"
		width="250"
		height="250"
		alt="Image from post"
	/>

	<h1>Picture</h1>
	<Picture
		src={post03Img}
		formats={["webp", "avif", "jpg"]}
		width="250"
		height="250"
		alt="Image from post"
	/>

	<h1>Picture with Sizes</h1>
	<!-- formats={['webp', 'avif', 'jpeg', 'png']} -->
	<!-- widths={[240, 540, 720, post05Img.width]}
  sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1600px) 720px, ${post05Img.width}px`} -->
	<!-- width={post05Img.width / 2}
  densities={[1.5, 2]} -->
	<Picture src={post05Img} alt="Imagen del post" />
	<div
		style={{
			height: "3000px",
		}}
	>
	</div>

	<img
		loading="lazy"
		src="/assets/images/post-01.png"
		width="250"
		height="250"
	/>
</MainLayout>

<style>
	@reference "tailwindcss";

	@apply text-white mt-10;
</style>
